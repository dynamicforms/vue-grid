{
  "name": "@dynamicforms/dynamicforms-vue-grid",
  "private": false,
  "version": "0.1.6",
  "type": "module",
  "description": "A (not so) simple, (but hopefully) fast vue grid component.",
  "author": "Jure Erznožnik",
  "files": [
    "dist/*"
  ],
  "main": "dist/dynamicforms-vue-grid.umd.cjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "require": "./dist/dynamicforms-vue-grid.umd.cjs",
      "import": "./dist/dynamicforms-vue-grid.js"
    },
    "./styles.css": "./dist/style.css"
  },
  "workspaces": [
    "docs"
  ],
  "scripts": {
    "build": "vite build",
    "test": "vitest run --coverage",
    "lint": "eslint src && vue-tsc --noEmit",
    "docs:dev": "npm run docs:dev -w docs",
    "docs:build": "npm run docs:build -w docs",
    "docs:preview": "npm run docs:preview -w docs"
  },
  "keywords": [
    "vue",
    "dynamicforms",
    "velis",
    "form-layout",
    "modal"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git@github.com:dynamicforms/vue-grid.git"
  },
  "issues": "https://github.com/dynamicforms/vue-grid/issues",
  "peerDependencies": {
    "@dynamicforms/vue-forms": "^0.4.9",
    "date-fns": "^4.1.0",
    "lodash-es": "^4.17.12",
    "natural-orderby": "^5.0.0",
    "vue": "^3.4",
    "vue-cached-icon": "^3.0.3",
    "vue-markdown-render": "^2.3.0",
    "vue-virtual-scroller": "^2.0.0-beta.8"
  },
  "devDependencies": {
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^22.14.1",
    "@vitejs/plugin-vue": "^5",
    "@vitest/coverage-istanbul": "^3",
    "@vue/test-utils": "^2.2.4",
    "@vue/tsconfig": "^0.7.0",
    "eslint-config-velis": "^1.1.16",
    "jsdom": "^26.0.0",
    "rollup-plugin-visualizer": "^5.14.0",
    "typescript": "^5",
    "vite": "^5",
    "vite-plugin-dts": "^4",
    "vite-plugin-eslint": "^1.8.1",
    "vitest": "^3",
    "vue-tsc": "^2"
  },
  "eslintConfig": {
    "extends": [
      "velis"
    ],
    "ignorePatterns": [
      "dist/*",
      "coverage/*",
      "node_modules/*",
      "docs/*",
      "vite.config.ts"
    ]
  }
}
